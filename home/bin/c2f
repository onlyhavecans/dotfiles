#!/usr/bin/env bash

INPUT="${1,,}"
if ! [[ "$INPUT" =~ ^(-?[0-9.]+)([cf])$ ]]; then
  echo "Usage: c2f <temp_value><unit>"
  echo "e.g. 'c2f 41c' or 'c2f 86f'"
  exit 1
fi

VALUE="${BASH_REMATCH[1]}"
UNIT="${BASH_REMATCH[2]}"

if [[ "$UNIT" == "c" ]]; then
  MSG="$(awk "BEGIN { printf \"%.1f\", ($VALUE * 9/5) + 32 }")°F"
else
  MSG="$(awk "BEGIN { printf \"%.1f\", ($VALUE - 32) * 5/9 }")°C"
fi

echo "$MSG"
command -v notify-send &>/dev/null && notify-send "c2f" "$MSG"
